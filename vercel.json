{
  "buildCommand": "bash build_web.sh",
  "outputDirectory": "web_game/build/web",
  "rewrites": [
    {
      "source": "/archives/:path*",
      "destination": "https://pygame-web.github.io/archives/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ]
}
